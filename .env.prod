VITE_SERVICE_BASE_URL=https://pt-test.csautodriver.com/platformadmin

VITE_APP_BASE_API=/platformadmin

# watermark
VITE_WATERMARK=N
# 是否开启 SSE 功能
VITE_APP_SSE=N
# 是否开启 websocket 功能
VITE_APP_WEBSOCKET=N

# app client id
VITE_APP_CLIENT_ID=e5cd7e4891bf95d1d19206ce24a7b32e

# 记住密码 AES 加密密钥
VITE_REMEMBER_ME_AES_KEY=pC4aO6cD2uU7hA0bK6iD4vE1mV8sU8xG

# 接口加密功能开关(如需关闭 后端也必须对应关闭)
